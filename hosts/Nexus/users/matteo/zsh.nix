{ pkgs, lib, ... }:
let
  ipmitool = lib.getExe pkgs.ipmitool;
in
{
  custom.zsh = {
    enable = true;
    extraAliases = {
      fan-manual = "sudo ${ipmitool} raw 0x30 0x30 0x01 0x00";
      fan-auto = "sudo ${ipmitool} raw 0x30 0x30 0x01 0x01";
      fan-10 = "sudo ${ipmitool} raw 0x30 0x30 0x02 0xff 0x0a";
      fan-20 = "sudo ${ipmitool} raw 0x30 0x30 0x02 0xff 0x14";
      fan-30 = "sudo ${ipmitool} raw 0x30 0x30 0x02 0xff 0x1e";
      fan-40 = "sudo ${ipmitool} raw 0x30 0x30 0x02 0xff 0x28";
      fan-50 = "sudo ${ipmitool} raw 0x30 0x30 0x02 0xff 0x32";
      fan-60 = "sudo ${ipmitool} raw 0x30 0x30 0x02 0xff 0x3c";
      fan-70 = "sudo ${ipmitool} raw 0x30 0x30 0x02 0xff 0x46";
      fan-80 = "sudo ${ipmitool} raw 0x30 0x30 0x02 0xff 0x50";
      fan-90 = "sudo ${ipmitool} raw 0x30 0x30 0x02 0xff 0x5a";
      fan-100 = "sudo ${ipmitool} raw 0x30 0x30 0x02 0xff 0x64";
    };
  };

  custom.shell-tools.enable = true;

  custom.atuin = {
    enable = true;
    syncAddress = "http://localhost:8888";
  };
}
