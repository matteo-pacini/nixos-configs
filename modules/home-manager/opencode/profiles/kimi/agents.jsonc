{
  // OpenCode "kimi" profile — agent definitions.
  // ==========================================================================
  // Lands at OPENCODE_CONFIG and is merged on top of the global opencode.jsonc.
  // Kimi-centric roster: every agentic role runs a Kimi K2 model. See
  // opencode.jsonc for verification commands.
  //
  // Conventions:
  //   * NO agent `prompt` field. In opencode v1.16.2 `agent.prompt` REPLACES
  //     the model's built-in base system prompt (session/llm/request.ts:60),
  //     which for Kimi is the ~95-line kimi.txt operating guide. Agent-scoped
  //     steering goes in the auto-loaded AGENTS.md instead (it APPENDS after
  //     the base prompt for every agent) — see modules/home-manager/opencode.nix.
  //   * transform.ts auto-injects temperature=1.0 for any kimi-k2.* id. It
  //     auto-injects top_p=0.95 ONLY for kimi-k2.5 (topP() whitelist) — k2.6 and
  //     k2.7-code are NOT on it, so those agents set top_p=0.95 explicitly. temp
  //     1.0 is also the ONLY value Moonshot K2.* permits (mismatch → HTTP 400).
  //   * `steps` defaults to Infinity if unset. Always cap explicitly.
  //   * `permission.write` is NOT a canonical key; `edit` gates the
  //     {edit, write, patch} tool group.
  //   * Reasoning depth: Kimi thinking is binary and effort levels are not
  //     reliably graded on OpenRouter K2.* endpoints, so no effort hints are
  //     relied upon. build/debug run always-thinking kimi-k2.7-code (reasoning
  //     preserved across multi-turn tool calls); plan uses the `think` variant.
  // ==========================================================================

  "agent": {

    // ------------------------------------------------------------------------
    // build — primary implementation agent (full coding/edit/bash).
    //   kimi-k2.7-code: coding-first, always-thinking, preserves reasoning
    //   across multi-turn tool calls (avoids the V4-class multi-turn 400),
    //   ~30% fewer thinking tokens than K2.6 — directly targets the
    //   over-think/loop failure mode. 256K ctx. steps=50 ≈ Moonshot multi-step
    //   eval ceiling. temp 1.0 auto-injected; top_p 0.95 explicit (k2.7-code
    //   not on the topP whitelist). No variant — always-thinking.
    //   https://openrouter.ai/moonshotai/kimi-k2.7-code
    // ------------------------------------------------------------------------
    "build": {
      "description": "Full-featured coding agent for implementation and complex changes. Writes code, runs tests, manages files, and executes system commands. Use for: building features, bug fixes, large refactors, dependency updates, and any task requiring code modifications.",
      "mode": "primary",
      "model": "openrouter/moonshotai/kimi-k2.7-code",
      "temperature": 1.0,
      "top_p": 0.95,
      "steps": 50
    },

    // ------------------------------------------------------------------------
    // plan — primary, read-only architecture/design. kimi-k2.6 with the `think`
    //   variant (thinking on). top_p 0.95 explicit (k2.6 not on topP whitelist).
    // ------------------------------------------------------------------------
    "plan": {
      "description": "Architecture and planning specialist. Analyzes code, designs solutions, and creates implementation plans without modifying files. Use for: system design, code review preparation, technical decisions, refactoring strategies, and understanding complex codebases.",
      "mode": "primary",
      "model": "openrouter/moonshotai/kimi-k2.6",
      "temperature": 1.0,
      "top_p": 0.95,
      "variant": "think",
      "steps": 20,
      "permission": {
        "edit": { "*": "deny" },
        "bash": { "*": "deny" }
      }
    },

    // ------------------------------------------------------------------------
    // explore — subagent, read-only codebase navigator. kimi-k2.5: cheap fast
    //   retriever, 262K ctx. transform.ts auto-injects BOTH temp=1.0 and
    //   top_p=0.95 for kimi-k2.5 (on the topP whitelist), so neither is set
    //   here. steps=40 for grep→read retrieval chains over large trees.
    //   https://openrouter.ai/moonshotai/kimi-k2.5
    // ------------------------------------------------------------------------
    "explore": {
      "description": "Fast codebase navigator for discovery and analysis. Searches files, finds references, maps dependencies, and answers questions about code structure. Use for: understanding unfamiliar codebases, finding functions/classes, tracing data flows, and locating configuration.",
      "mode": "subagent",
      "model": "openrouter/moonshotai/kimi-k2.5",
      "steps": 40,
      "permission": {
        "edit": { "*": "deny" },
        "bash": { "*": "deny" },
        "read": { "*": "allow" },
        "glob": { "*": "allow" },
        "grep": { "*": "allow" }
      }
    },

    // ------------------------------------------------------------------------
    // review — subagent, code quality + security review. kimi-k2.6 (GA). temp
    //   1.0 auto-injected; top_p 0.95 explicit (k2.6 not on topP whitelist).
    // ------------------------------------------------------------------------
    "review": {
      "description": "Code quality and security reviewer. Identifies bugs, security vulnerabilities, performance issues, and style violations. Use for: PR reviews, security audits, best practice enforcement, and spotting potential edge cases or anti-patterns.",
      "mode": "subagent",
      "model": "openrouter/moonshotai/kimi-k2.6",
      "temperature": 1.0,
      "top_p": 0.95,
      "steps": 20,
      "permission": {
        "edit": { "*": "deny" },
        "bash": { "*": "deny" },
        "read": { "*": "allow" },
        "glob": { "*": "allow" },
        "grep": { "*": "allow" }
      }
    },

    // ------------------------------------------------------------------------
    // debug — subagent, troubleshooting with bash. kimi-k2.7-code
    //   (always-thinking; reasoning preserved across diagnostic loops). temp 1.0
    //   auto-injected; top_p 0.95 explicit. steps=30 for
    //   test→observe→re-hypothesise→test.
    // ------------------------------------------------------------------------
    "debug": {
      "description": "Diagnostic specialist for troubleshooting and investigation. Runs tests, inspects logs, reproduces issues, and analyzes error patterns. Use for: debugging failures, investigating performance issues, analyzing test results, and diagnosing system problems.",
      "mode": "subagent",
      "model": "openrouter/moonshotai/kimi-k2.7-code",
      "temperature": 1.0,
      "top_p": 0.95,
      "steps": 30,
      "permission": {
        "edit": { "*": "deny" },
        "bash": { "*": "allow" },
        "read": { "*": "allow" },
        "glob": { "*": "allow" },
        "grep": { "*": "allow" }
      }
    }
  }
}
