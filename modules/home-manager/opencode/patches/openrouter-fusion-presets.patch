+// OpenRouter Fusion presets exposed as model variants (backport of
+// anomalyco/opencode#32332, generalized). Builtin quality/budget plus any
+// presets injected via the OPENCODE_FUSION_PRESETS env var
+// (JSON: name -> { analysis_models, model }), so a profile ships its own panel
+// without editing this patch.
+function openRouterFusionVariants(): Record<string, Record<string, any>> {
+  const preset = (analysis: readonly string[], judge?: string) => ({
+    plugins: [{ id: "fusion", analysis_models: [...analysis], model: judge ?? analysis[0] }],
+  })
+  const out: Record<string, Record<string, any>> = {
+    quality: preset(["~anthropic/claude-opus-latest", "~openai/gpt-latest", "~google/gemini-pro-latest"]),
+    budget: preset(["~google/gemini-flash-latest", "~moonshotai/kimi-latest", "deepseek/deepseek-v4-pro"]),
+  }
+  try {
+    const injected = JSON.parse(process.env["OPENCODE_FUSION_PRESETS"] ?? "{}")
+    for (const [name, cfg] of Object.entries(injected)) {
+      const c = cfg as { analysis_models?: unknown; model?: unknown }
+      if (Array.isArray(c?.analysis_models))
+        out[name] = preset(c.analysis_models as string[], typeof c.model === "string" ? c.model : undefined)
+    }
+  } catch {}
+  return out
+}
+
 export function variants(model: Provider.Model): Record<string, Record<string, any>> {
+  if (model.api.npm === "@openrouter/ai-sdk-provider" && model.api.id === "openrouter/fusion")
+    return openRouterFusionVariants()
+
   if (!model.capabilities.reasoning) return {}
 
   const id = model.id.toLowerCase()
